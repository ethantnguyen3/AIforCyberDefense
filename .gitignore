# =========================
# Data & Logs (SIEM Baseline)
# =========================
# Ignore all general log files to prevent uploading massive SOC data drops
*.log

# EXCEPTIONS: Force Git to track the specific sample logs needed for your grading rubric
!evidence/baseline_logs/*.log

# Ignore large packet captures or local databases unless specifically needed
*.pcap
*.sqlite3

